<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select reason for blocking"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <CheckBox
        android:id="@+id/cbSpam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Spam"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbHarassment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Harassment"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbFraud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fraud calls"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbOffensive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Offensive"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbAbusing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abusing"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbTelemarketing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Telemarketing"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbOther"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Other"
        android:textSize="16sp"
        android:padding="8dp"/>

    <CheckBox
        android:id="@+id/cbForMeOnly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="For me only"
        android:textSize="16sp"
        android:padding="8dp"
        android:textColor="@color/brand_red"/>

    <EditText
        android:id="@+id/etSuggestedName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_edittext"
        android:hint="Suggest name (optional)"
        android:padding="12dp"
        android:textSize="16sp" />

</LinearLayout>