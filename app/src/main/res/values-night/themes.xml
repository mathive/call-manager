<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CallManager" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_red</item>
        <item name="colorPrimaryVariant">@color/brand_black</item>
        <item name="colorOnPrimary">@color/brand_white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_red</item>
        <item name="colorSecondaryVariant">@color/brand_red</item>
        <item name="colorOnSecondary">@color/brand_black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/brand_black</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="windowSplashScreenBackground">@color/brand_black</item>
        <item name="postSplashScreenTheme">@style/Theme.CallManager</item>
    </style>
</resources>